NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=sofra_db
DB_USER=sofra
DB_PASSWORD=sofra123

# Redis
REDIS_URL=redis://:redis123@redis:6379
REDIS_PASSWORD=redis123

# RabbitMQ
RABBITMQ_URL=amqp://sofra:sofra123@rabbitmq:5672
RABBITMQ_USER=sofra
RABBITMQ_PASSWORD=sofra123

# JWT
JWT_SECRET=sofra_secret_key_2026
JWT_EXPIRES_IN=7d

# SMS (console = просто показывает код в терминале)
SMS_PROVIDER=console

# Firebase (пока пустые)
FIREBASE_PROJECT_ID=sofra
FIREBASE_PRIVATE_KEY=sofra
FIREBASE_CLIENT_EMAIL=sofra@sofra.com

# Kaspi (пока пустые)
KASPI_MERCHANT_ID=test
KASPI_SECRET_KEY=test

# Halyk (пока пустые)
HALYK_CLIENT_ID=test
HALYK_CLIENT_SECRET=test
HALYK_TERMINAL_ID=test

APP_URL=http://localhost:3000
